#!/bin/bash
# Reads .desktop files and builds a tab-separated cache: exec|name|icon_path
CACHE="$HOME/.cache/eww/apps.cache"
mkdir -p "$(dirname "$CACHE")"

resolve_icon() {
    local icon="$1"
    [ -z "$icon" ] && return
    [ -f "$icon" ] && echo "$icon" && return
    for idir in /usr/share/icons /usr/local/share/icons "$HOME/.local/share/icons"; do
        [ -d "$idir" ] || continue
        local found
        found=$(find "$idir" -maxdepth 5 -name "${icon}.*" -type f 2>/dev/null | head -1)
        [ -n "$found" ] && echo "$found" && return
    done
    [ -f "/usr/share/pixmaps/${icon}.png" ] && echo "/usr/share/pixmaps/${icon}.png" && return
}

> "$CACHE"
for dir in /usr/share/applications /usr/local/share/applications "$HOME/.local/share/applications"; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.desktop; do
        [ -f "$f" ] || continue
        grep -q '^NoDisplay=true' "$f" && continue
        grep -q '^Hidden=true' "$f" && continue
        name=$(grep -m1 '^Name=' "$f" | cut -d= -f2-)
        exec_line=$(grep -m1 '^Exec=' "$f" | cut -d= -f2-)
        icon=$(grep -m1 '^Icon=' "$f" | cut -d= -f2-)
        [ -z "$name" ] || [ -z "$exec_line" ] && continue
        icon_path=$(resolve_icon "$icon")
        printf '%s\t%s\t%s\n' "$exec_line" "$name" "$icon_path" >> "$CACHE"
    done
done
sort -t$'\t' -k2 -f -o "$CACHE" "$CACHE"
