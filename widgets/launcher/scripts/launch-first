#!/bin/bash
# Launches the first matching app and closes the launcher
CACHE="$HOME/.cache/eww/apps.cache"
QUERY=$(eww get search_query 2>/dev/null)

if [ -z "$QUERY" ]; then
    FIRST=$(head -1 "$CACHE")
else
    FIRST=$(awk -F'\t' -v q="$QUERY" '
    BEGIN { n = split(q, words, " ") }
    {
        name = $2
        ok = 1
        for (i = 1; i <= n; i++) {
            if (words[i] != "" && tolower(name) !~ tolower(words[i])) { ok = 0; break }
        }
        if (ok) { print; exit }
    }' "$CACHE")
fi

if [ -n "$FIRST" ]; then
    EXEC=$(echo "$FIRST" | cut -f1)
    EXEC=$(echo "$EXEC" | sed 's/%[fFuUdDn]//g')
    eval "$EXEC" &
    disown
fi

eww close launcher
