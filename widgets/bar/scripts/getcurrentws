#!/bin/bash
# Outputs current workspace number, follows changes
if command -v xprop >/dev/null 2>&1; then
    # X11 - poll xprop for _NET_CURRENT_DESKTOP
    last=""
    while true; do
        ws=$(xprop -root _NET_CURRENT_DESKTOP 2>/dev/null | awk -F'= ' '{print $2 + 1}')
        if [ -n "$ws" ] && [ "$ws" != "$last" ]; then
            echo "$ws"
            last="$ws"
        fi
        sleep 0.3
    done
elif command -v swaymsg >/dev/null 2>&1; then
    # Sway - subscribe to workspace events
    swaymsg -t subscribe -m '[ "workspace" ]' 2>/dev/null | while read -r line; do
        ws=$(echo "$line" | jq -r '.current.num // empty')
        [ -n "$ws" ] && echo "$ws"
    done
else
    echo "1"
fi
