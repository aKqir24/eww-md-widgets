#!/bin/bash
# Outputs current workspace number (1-indexed) and streams updates live

if command -v xprop >/dev/null 2>&1; then # --- X11 Path (Event-driven) ---
    parse_ws() {
        local val="${1##*= }"
        if [[ "$val" =~ ^[0-9]+$ ]]; then
            echo $((val + 1))
        fi
    }

    last=$(parse_ws "$(xprop -root _NET_CURRENT_DESKTOP 2>/dev/null)")
    [[ -n "$last" ]] && echo "$last"

    xprop -spy -root _NET_CURRENT_DESKTOP 2>/dev/null | while read -r line; do
        ws=$(parse_ws "$line")
        if [[ -n "$ws" && "$ws" != "$last" ]]; then
            echo "$ws"
            last="$ws"
        fi
    done

elif command -v swaymsg >/dev/null 2>&1; then # --- Sway Path (Stream-driven) ---
    
    swaymsg -t get_workspaces 2>/dev/null | jq -r '.[] | select(.focused == true).num'
    swaymsg -t subscribe -m '["workspace"]' 2>/dev/null | jq -r --unbuffered '.current.num // empty'

else
    echo "1"
fi
