#!/bin/bash
# Outputs space-padded list of occupied workspace numbers: " 1 3 5 "
if command -v wmctrl >/dev/null 2>&1; then
    wmctrl -l 2>/dev/null | awk '{print $2}' | sort -un | awk '{printf " %s ", $0}'
elif command -v swaymsg >/dev/null 2>&1; then
    swaymsg -t get_workspaces 2>/dev/null | jq -r '[.[] | select(.output != "none") | .num] | .[]' | awk '{printf " %s ", $0}'
else
    echo ""
fi
