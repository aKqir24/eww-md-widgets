#!/bin/bash
case "$1" in
    up)
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
        val=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%d", $2 * 100}')
        muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -c '\[MUTED\]')
        [ "$muted" -gt 0 ] && val=0
        eww update volume="$val"
        ;;
    down)
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
        val=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%d", $2 * 100}')
        muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -c '\[MUTED\]')
        [ "$muted" -gt 0 ] && val=0
        eww update volume="$val"
        ;;
    right)
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
        val=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%d", $2 * 100}')
        muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -c '\[MUTED\]')
        [ "$muted" -gt 0 ] && val=0
        eww update volume="$val"
        ;;
    left)
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
        val=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%d", $2 * 100}')
        muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -c '\[MUTED\]')
        [ "$muted" -gt 0 ] && val=0
        eww update volume="$val"
        ;;
    mute)
        wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
        val=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%d", $2 * 100}')
        muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -c '\[MUTED\]')
        [ "$muted" -gt 0 ] && val=0
        eww update volume="$val"
        ;;
    set)
        val=$(( ($2 + 2) / 5 * 5 ))
        if [ "$val" -gt 100 ]; then val=100; fi
        if [ "$val" -lt 0 ]; then val=0; fi
        wpctl set-volume @DEFAULT_AUDIO_SINK@ "$(echo "scale=2; $val / 100" | bc)"
        eww update volume="$val"
        ;;
esac
